# OCS Answer Server 配置示例
# 复制此文件为 .env 并填入实际值

# ============ 服务器配置 ============
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ============ 大模型API配置 ============
# 支持的API类型: openai, claude, gemini, openrouter, custom
API_PROVIDER=openai

# OpenAI 格式配置
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Claude 格式配置 (如果使用Claude API)
# CLAUDE_API_URL=https://api.anthropic.com/v1/messages
# CLAUDE_API_KEY=your-claude-api-key-here
# CLAUDE_MODEL=claude-3-haiku-20240307

# Gemini 格式配置 (如果使用Gemini API)
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-pro

# OpenRouter 配置 (聚合多种AI模型)
# OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
# OPENROUTER_API_KEY=your-openrouter-api-key-here
# OPENROUTER_MODEL=anthropic/claude-3-haiku
# OPENROUTER_SITE_URL=https://your-site-url.com (可选)
# OPENROUTER_SITE_NAME=Your App Name (可选)

# 自定义API配置 (适用于兼容OpenAI格式的API)
# CUSTOM_API_URL=https://your-custom-api.com/v1/chat/completions
# CUSTOM_API_KEY=your-custom-api-key

# ============ Prompt配置 ============
# 系统提示词模板
SYSTEM_PROMPT=你是一个专业的分析化学助手。请根据题目内容给出准确的答案。

# 问题前缀
QUESTION_PREFIX="题目："
# 选项前缀
OPTIONS_PREFIX="选项："
# 类型前缀
TYPE_PREFIX="题型："

# ============ 请求限制 ============
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============ 调试选项 ============
# 是否在API响应中保留大模型原始响应(调试用，默认关闭)
RETAIN_LLM_RESPONSE=false
# 是否将大模型原始响应写入日志(调试用，默认关闭)
RETAIN_LLM_RESPONSE_IN_LOGS=false
